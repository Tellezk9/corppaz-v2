---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";
import logoBig from "../assets/corppaz-icon-big.png";
import { vacantesList } from "../components/data/vacantesData.js";

// Extraer áreas y contratos únicos de la base de datos
const areas = [...new Set(vacantesList.map((v: any) => v.area))].filter(
  Boolean,
);
const contratos = [
  ...new Set(vacantesList.map((v: any) => v.contractType)),
].filter(Boolean);
---

<Layout
  title="Convocatorias y Vacantes — CORPPAZ"
  description="Únete a nuestro equipo y contribuye al desarrollo agropecuario, social y sostenible de nuestras comunidades."
>
  <Navbar />

  <!-- ===== HEADER DE PAGINA ===== -->
  <section class="page-header">
    <div class="cta-rings">
      <Image 
        src={logoBig}
        alt="Imagen de fondo" 
        width={525}
        height={510} 
      />
    </div>
    <div class="wrap">
      <span class="eyebrow reveal">Únete al equipo</span>
      <h1 class="reveal">
        Convocatorias y <span class="accent-italic">vacantes</span>
      </h1>
      <p class="reveal">
        Únete a nuestro equipo y contribuye al desarrollo agropecuario, social y
        sostenible de nuestras comunidades. Explora las oportunidades laborales
        disponibles y postúlate.
      </p>

      <div class="filters reveal">
        <input type="search" id="v-search" placeholder="Buscar vacante..." />
        <select id="v-area">
          <option value="">Todas las áreas</option>
          {areas.map((area) => <option value={area}>{area}</option>)}
        </select>
        <select id="v-contrato">
          <option value="">Todos los contratos</option>
          {
            contratos.map((contrato) => (
              <option value={contrato}>{contrato}</option>
            ))
          }
        </select>
      </div>
    </div>
  </section>

  <!-- ===== GRID DE VACANTES ===== -->
  <section class="vacantes-section">
    <div class="wrap">
      <div class="vacantes-grid" id="v-grid">
        {
          vacantesList.map((v: any) => (
            <div
              class="v-card-reveal reveal"
              data-title={v.title.toLowerCase()}
              data-area={v.area}
              data-contrato={v.contractType}
            >
              <a href={`/vacante-detalle?id=${v.id}`} class="v-card">
                <h3>{v.title}</h3>
                <div class="v-loc">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                  >
                    <path d="M12 21s-7-6-7-11a7 7 0 0114 0c0 5-7 11-7 11z" />
                    <circle cx="12" cy="10" r="2.5" />
                  </svg>
                  {v.location}
                </div>
                <div class="v-foot">
                  <span class="v-tag">{v.area}</span>
                  <span class="v-link">Ver detalles →</span>
                </div>
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* Variables locales */
  .page-header,
  .vacantes-section {
    --primary: var(--color-primary, #043a39);
    --secondary: var(--color-secondary, #f8aea1);
    --secondary-deep: #ef8f7d;
    --bg: var(--color-bg, #faf8f5);
    --surface: var(--color-surface, #ffffff);
    --text: var(--color-dark, #202124);
    --text-soft: #5b6360;
    --neutral: #6b7280;
    --divider: var(--color-divider, #e8e8e8);
    --font-display: var(--font-title, "DM Serif Display", serif);
    --font-accent: var(--font-serif, "Instrument Serif", serif);
    --font-body: "Inter", sans-serif;
  }

  .wrap {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 clamp(24px, 6vw, 96px);
  }

  .eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--secondary-deep);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
  }

  .eyebrow::before {
    content: "";
    width: 22px;
    height: 1px;
    background: var(--secondary-deep);
    display: inline-block;
  }

  .accent-italic {
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 500;
    color: var(--secondary-deep);
  }

  /* ===== PAGE HEADER ===== */
  .page-header {
    padding: min(10vw, 90px) 0 50px;
    padding-top: calc(min(10vw, 90px) + 80px);
    position: relative;
    overflow: hidden;
  }

  .page-header .wrap {
    position: relative;
    z-index: 1;
  }

  .page-header h1 {
    font-family: var(--font-body);
    font-weight: 600;
    letter-spacing: -0.04em;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    line-height: 1.02;
    color: var(--primary);
    margin-bottom: 18px;
    max-width: 16ch;
  }

  .page-header p {
    color: var(--text-soft);
    font-size: 1.05rem;
    max-width: 56ch;
  }

  .cta-rings {
    position: absolute;
    top: -15%;
    right: -5%;
    width: 480px;
    opacity: 0.15;
    pointer-events: none;
  }

  .cta-rings img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ===== FILTROS ===== */
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    padding: 22px;
    background: var(--surface);
    border: 1px solid var(--divider);
    border-radius: 20px;
    margin-top: 36px;
    box-shadow: 0 30px 60px -40px rgba(4, 58, 57, 0.2);
  }

  .filters input[type="search"] {
    flex: 2 1 220px;
    min-width: 180px;
    border: 1px solid var(--divider);
    border-radius: 100px;
    padding: 13px 20px;
    font-size: 0.92rem;
    color: var(--text);
    background: var(--bg);
    font-family: var(--font-body);
  }

  .filters select {
    flex: 1 1 160px;
    border: 1px solid var(--divider);
    border-radius: 100px;
    padding: 13px 18px;
    font-size: 0.88rem;
    color: var(--text);
    background: var(--bg);
    appearance: none;
    font-family: var(--font-body);
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%235b6360' stroke-width='2'><path d='M6 9l6 6 6-6'/></svg>");
    background-repeat: no-repeat;
    background-position: right 16px center;
    background-size: 14px;
  }

  .filters input:focus,
  .filters select:focus {
    outline: none;
    border-color: var(--secondary-deep);
  }

  /* ===== GRID DE VACANTES ===== */
  .vacantes-section {
    padding: 0px 0 min(12vw, 110px);
  }

  .vacantes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .v-card-reveal {
    display: flex;
    flex-direction: column;
  }

  .v-card {
    background: var(--surface);
    border: 1px solid var(--divider);
    border-radius: 20px;
    padding: 30px;
    display: flex;
    flex-direction: column;
    min-height: 230px;
    height: 100%;
    width: 100%;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .v-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 30px 60px -30px rgba(4, 58, 57, 0.28);
  }

  .v-card h3 {
    font-size: 1.12rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--primary);
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .v-loc {
    display: flex;
    gap: 8px;
    align-items: flex-start;
    color: var(--text-soft);
    font-size: 0.85rem;
    margin-bottom: auto;
  }

  .v-loc svg {
    width: 15px;
    height: 15px;
    flex: none;
    margin-top: 2px;
    color: var(--secondary-deep);
  }

  .v-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 22px;
    padding-top: 18px;
    border-top: 1px solid var(--divider);
  }

  .v-tag {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--neutral);
  }

  .v-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.82rem;
    font-weight: 600;
    white-space: nowrap;
    background: var(--secondary-deep);
    color: #fff;
    padding: 10px 22px;
    border-radius: 100px;
    transition:
      background 0.25s ease,
      transform 0.25s ease;
  }

  .v-link:hover {
    background: var(--primary);
    transform: translateY(-2px);
  }

  /* ===== REVEAL ===== */
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.7s ease,
      transform 0.7s ease;
  }

  .reveal.in {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 980px) {
    .vacantes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .cta-rings {
      width: 280px;
      top: -5%;
      right: -8%;
      opacity: 0.08;
    }
  }

  @media (max-width: 620px) {
    .vacantes-grid {
      grid-template-columns: 1fr;
    }

    .filters {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      padding: 16px;
      margin-top: 26px;
    }

    .filters input[type="search"] {
      grid-column: span 2;
      width: 100%;
      min-width: 0;
    }

    .filters select {
      width: 100%;
      min-width: 0;
      font-size: 0.85rem;
      padding: 13px 12px;
      background-position: right 10px center;
    }
  }
</style>

<script>
  const initVacantes = () => {
    // Reveal animations
    const els = document.querySelectorAll(".reveal");
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("in");
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.1 },
    );
    els.forEach((el) => io.observe(el));

    // Filtrado
    const search = document.getElementById("v-search") as HTMLInputElement;
    const areaSel = document.getElementById("v-area") as HTMLSelectElement;
    const contratoSel = document.getElementById(
      "v-contrato",
    ) as HTMLSelectElement;
    const wrappers = document.querySelectorAll<HTMLElement>(
      "#v-grid .v-card-reveal",
    );

    function applyFilters() {
      if (!search || !areaSel || !contratoSel) return;
      const q = search.value.trim().toLowerCase();
      const area = areaSel.value;
      const contrato = contratoSel.value;
      wrappers.forEach((c) => {
        const matchesText = (c.dataset.title || "").includes(q);
        const matchesArea = !area || c.dataset.area === area;
        const matchesContrato = !contrato || c.dataset.contrato === contrato;
        c.style.display =
          matchesText && matchesArea && matchesContrato ? "" : "none";
      });
    }

    search?.addEventListener("input", applyFilters);
    areaSel?.addEventListener("change", applyFilters);
    contratoSel?.addEventListener("change", applyFilters);
  };

  initVacantes();
  document.addEventListener("astro:after-swap", initVacantes);
</script>
