    height: 1px;
    background: var(--secondary-deep);
    display: inline-block;
  }

  .accent-italic {
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 500;
    color: var(--secondary-deep);
    letter-spacing: 0.04rem;
