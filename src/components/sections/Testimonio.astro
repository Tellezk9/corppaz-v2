<section class="testimonio section" id="testimonio">
  <div class="wrap">
    <div class="t-card reveal">
      
      <div class="t-slide active">
        <div class="t-avatar">
          <img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?q=80&w=300&auto=format&fit=crop" alt="Marisol Peña" />
        </div>
        <p class="t-quote">"Recibir el kit de alimentos en el momento más difícil nos devolvió la tranquilidad. Sentimos que alguien sí estaba pendiente de nosotros."</p>
        <div class="t-name">Marisol Peña</div>
        <div class="t-role">Beneficiaria, asistencia alimentaria — Norte de Santander</div>
      </div>
      
      <div class="t-slide">
        <div class="t-avatar">
          <img src="https://images.unsplash.com/photo-1633332755192-727a05c4013d?q=80&w=300&auto=format&fit=crop" alt="Édgar Contreras" />
        </div>
        <p class="t-quote">"El acompañamiento técnico nos enseñó a mejorar la producción del hato. Hoy la asociación de ganaderos es más fuerte gracias a ese proceso."</p>
        <div class="t-name">Édgar Contreras</div>
        <div class="t-role">Productor ganadero, San Faustino y Guaramito</div>
      </div>
      
      <div class="t-slide">
        <div class="t-avatar">
          <img src="https://images.unsplash.com/photo-1531123897727-8f129e1688ce?q=80&w=300&auto=format&fit=crop" alt="Lucía Fernández" />
        </div>
        <p class="t-quote">"Nos ayudaron a organizarnos como comunidad. Ahora sabemos cómo gestionar nuestros propios proyectos y no depender solo de la ayuda externa."</p>
        <div class="t-name">Lucía Fernández</div>
        <div class="t-role">Lideresa comunitaria, Toledo</div>
      </div>
      
      <div class="t-dots">
        <button class="t-dot active" aria-label="Testimonio 1"></button>
        <button class="t-dot" aria-label="Testimonio 2"></button>
        <button class="t-dot" aria-label="Testimonio 3"></button>
      </div>

    </div>
  </div>
</section>

<style>
  /* Variables locales de compatibilidad */
  .testimonio {
    --primary: var(--color-primary, #043a39);
    --bg: var(--color-bg, #faf8f5);
    --surface: var(--color-surface, #ffffff);
    --text-soft: #5b6360;
    --font-accent: var(--font-serif, "Instrument Serif", serif);
    --font-body: "Inter", sans-serif;
  }

  /* ===== ESTILOS LOCALES / UTILIDADES ===== */
  .wrap {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 clamp(24px, 6vw, 96px);
  }

  .section {
    padding: min(14vw, 120px) 0;
  }

  /* ===== TESTIMONIO ===== */
  .testimonio {
    background: var(--bg);
  }

  .t-card {
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
  }

  .t-slide {
    grid-area: 1 / 1;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.5s ease, transform 0.5s ease, visibility 0.5s;
    transform: translateY(15px);
  }

  .t-slide.active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .t-avatar {
    width: 76px;
    height: 76px;
    border-radius: 50%;
    overflow: hidden;
    margin: 0 auto 28px;
    border: 3px solid var(--surface);
    box-shadow: 0 10px 30px rgba(4, 58, 57, 0.15);
  }

  .t-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .t-quote {
    font-family: var(--font-accent);
    font-style: italic;
    font-size: clamp(1.4rem, 2.6vw, 2rem);
    line-height: 1.4;
    color: var(--primary);
    margin-bottom: 26px;
  }

  .t-name {
    font-weight: 600;
    color: var(--primary);
  }

  .t-role {
    color: var(--text-soft);
    font-size: 0.88rem;
  }

  .t-dots {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-top: 36px;
  }

  .t-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--divider, #e8e8e8);
    border: none;
    cursor: pointer;
    transition: background 0.3s, transform 0.3s;
    padding: 0;
  }

  .t-dot.active {
    background: var(--secondary-deep, #ef8f7d);
    transform: scale(1.3);
  }

  /* ===== ANIMACIONES REVEAL LOCALES ===== */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.8s ease,
      transform 0.8s ease;
  }

  .reveal.in {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const initTestimoniales = () => {
    const section = document.getElementById("testimonio");
    if (!section) return;

    // Reveal con IntersectionObserver
    const els = section.querySelectorAll(".reveal");
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("in");
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    els.forEach((el) => io.observe(el));

    // Rotación de Testimonios
    const slides = section.querySelectorAll(".t-slide");
    const dots = section.querySelectorAll(".t-dot");
    let tIndex = 0;
    let tTimer: any = null;

    function showSlide(i: number) {
      if (!slides.length || !dots.length) return;
      slides.forEach((s) => s.classList.remove("active"));
      dots.forEach((d) => d.classList.remove("active"));
      slides[i].classList.add("active");
      dots[i].classList.add("active");
      tIndex = i;
    }

    function nextSlide() {
      showSlide((tIndex + 1) % slides.length);
    }

    function startAutoplay() {
      tTimer = setInterval(nextSlide, 6000);
    }

    if (slides.length) {
      showSlide(0); // Forzar que empiece en el primer testimonio
      startAutoplay();
      dots.forEach((dot, i) => {
        dot.addEventListener("click", () => {
          clearInterval(tTimer);
          showSlide(i);
          startAutoplay();
        });
      });
    }
  };

  initTestimoniales();
  document.addEventListener("astro:after-swap", initTestimoniales);
</script>
