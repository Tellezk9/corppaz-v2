<style>
  /* Variables locales de compatibilidad */
  .hacemos {
    --primary: var(--color-primary, #043a39);
    --secondary-deep: #ef8f7d;
    --secondary: var(--color-secondary, #f8aea1);
    --divider: var(--color-divider, #e8e8e8);
    --bg: var(--color-bg, #faf8f5);
    --surface: var(--color-surface, #ffffff);
    --text-soft: #5b6360;
    --font-display: var(--font-title, "DM Serif Display", serif);
    --font-body: "Inter", sans-serif;
    --font-accent: var(--font-serif, "Instrument Serif", serif);
  }

  /* ===== ESTILOS LOCALES / UTILIDADES ===== */
  .wrap {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 clamp(24px, 6vw, 96px);
  }

  .accent-italic {
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 500;
    color: var(--secondary-deep);
    letter-spacing: 0.04rem;
  }

  .section {
    padding: min(5vw, 120px) 0;
  }

  .section-head {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 48px;
    align-items: end;
    margin-bottom: 64px;
  }

  .section-head h2 {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: clamp(2.1rem, 3.6vw, 3.1rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--primary);
  }

  .section-head p {
    color: var(--text-soft);
    font-size: 1rem;
    max-width: 38ch;
  }

  /* ===== QUE HACEMOS ===== */
  .hacemos {
    background: var(--surface);
  }

  .hacemos-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .ac-card {
    position: relative;
    background: var(--bg);
    border: 1px solid var(--divider);
    border-radius: 20px;
    padding: 38px 28px;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease;
  }

  .ac-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 30px 60px -28px rgba(4, 58, 57, 0.28);
    border-color: transparent;
  }

  .ac-num {
    position: absolute;
    top: 26px;
    right: 26px;
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--divider);
  }

  .ac-icon {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: rgba(248, 174, 161, 0.28);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--secondary-deep);
    margin-bottom: 26px;
  }

  .ac-icon svg {
    width: 23px;
    height: 23px;
    display: block;
  }

  .ac-card h4 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--primary);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .ac-card p {
    color: var(--text-soft);
    font-size: 0.89rem;
    line-height: 1.65;
  }

  /* ===== ANIMACIONES REVEAL LOCALES ===== */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.8s ease,
      transform 0.8s ease;
  }

  .reveal.in {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 980px) {
    .hacemos-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .section-head {
      grid-template-columns: 1fr;
      gap: 20px;
      margin-bottom: 40px;
    }
  }

  @media (max-width: 560px) {
    .hacemos-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const setupReveal = () => {
    const section = document.getElementById("hacemos");
    if (!section) return;
    const els = section.querySelectorAll(".reveal");
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("in");
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.15 },
    );
    els.forEach((el) => io.observe(el));
  };

  setupReveal();
  document.addEventListener("astro:after-swap", setupReveal);
</script>
