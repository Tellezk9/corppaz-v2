---
import heroImg from "../../assets/background.png";
import { Image } from "astro:assets";
import leaft from "../../assets/decoration/leaf.svg";
---

<section class="herov2" id="hero">
  <div class="herov2__bg">
    <Image
      src={heroImg}
      alt="Familia colombiana sembrando una planta juntos en el campo"
      class="herov2__img"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      quality={85}
    />
    <div class="herov2__overlay"></div>
  </div>

  <div class="herov2__content">
    <!-- Eyebrow -->
    <p class="herov2__eyebrow">
      <Image
        src={leaft}
        alt="Hoja"
        class="herov2__leaft"
        width={18}
        height={18}
        loading="eager"
      />
      Construimos un futuro mejor
    </p>

    <!-- Title with individual accent borders -->
    <div class="herov2__title-block">
      <div class="herov2__title-line herov2__title-line--secondary">
        <h1 class="herov2__title">
          Construimos<br />
          <span class="herov2__accent herov2__accent--secondary">bienestar,</span>
        </h1>
      </div>
      <div class="herov2__title-line herov2__title-line--primary">
        <p class="herov2__title herov2__title--sub">
          sembramos<br />
          <span class="herov2__accent herov2__accent--primary">esperanza.</span>
        </p>
      </div>
    </div>

    <p class="herov2__subtitle">
      Proyectos que transforman vidas, fortalecen<br />
      comunidades y construyen país.
    </p>

    <!-- Buttons -->
    <div class="herov2__buttons">
      <a href="/proyectos" class="herov2__cta herov2__cta--primary" id="hero-cta-v2">
        Conoce nuestros proyectos
        <span class="herov2__cta-arrow">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </span>
      </a>
      <a href="/trabaja-con-nosotros" class="herov2__cta herov2__cta--outline">
        Trabaja con nosotros
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .herov2 {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 700px;
    max-height: 1080px;
    overflow: hidden;
  }

  /* ── Background ── */
  .herov2__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .herov2__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .herov2__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to right,
        rgba(0, 0, 0, 0.55) 0%,
        rgba(0, 0, 0, 0.25) 45%,
        transparent 75%
      ),
      linear-gradient(
        to top,
        rgba(0, 0, 0, 0.5) 0%,
        rgba(0, 0, 0, 0.2) 40%,
        rgba(0, 0, 0, 0.05) 60%,
        transparent 100%
      );
  }

  /* ── Content ── */
  .herov2__content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    height: 100%;
    max-width: 1320px;
    margin-inline: auto;
    padding: 0 var(--space-3xl) var(--space-3xl);
  }

  /* ── Eyebrow ── */
  .herov2__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-lg);
  }

  /* ── Title Block ── */
  .herov2__title-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: var(--space-lg);
  }

  .herov2__title-line {
    padding-left: var(--space-lg);
    border-left: 3px solid;
  }

  .herov2__title-line--secondary {
    border-color: var(--color-secondary);
  }

  .herov2__title-line--primary {
    border-color: #5cecd6;
  }

  .herov2__title,
  .herov2__title--sub {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(2.25rem, 3.5vw + 0.5rem, 3.75rem);
    line-height: 0.85;
    letter-spacing: -3px;
    color: #fff;
    margin: 0;
  }

  .herov2__accent {
    font-family: var(--font-title);
    font-style: italic;
    font-weight: 400;
  }

  .herov2__accent--secondary {
    color: var(--color-secondary);
  }

  .herov2__accent--primary {
    color: #5cecd6;
    text-shadow: 0 1px 8px rgba(255, 255, 255, 0.15);
  }

  /* ── Subtitle ── */
  .herov2__subtitle {
    font-family: var(--font-body);
    font-size: clamp(0.875rem, 1vw + 0.2rem, 1rem);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.5;
    margin-bottom: var(--space-lg);
    max-width: 400px;
  }

  /* ── Buttons ── */
  .herov2__buttons {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .herov2__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    padding: 12px 24px;
    border-radius: var(--radius-full);
    letter-spacing: 0.2px;
    transition: all 0.3s ease;
  }

  .herov2__cta--primary {
    color: #fff;
    border-radius: 15px;
    background: linear-gradient(1deg, #0b968a, #0a6967);
    letter-spacing: -0.025em;
    box-shadow: 0px -1px #13ffeb, 0px 1px #1ad3c3, 0px 0px 0px 1px #0d968a;
    font-weight: 300;
    border: none;
  }

  .herov2__cta--primary:hover {
    transform: translateY(-2px);
    filter: brightness(1.1);
    box-shadow: 0px -1px #13ffeb, 0px 2px 8px rgba(26, 211, 195, 0.4), 0px 0px 0px 1px #0d968a;
  }

  .herov2__cta--outline {
    position: relative;
    overflow: hidden;
    z-index: 1;
    color: var(--color-primary);
    background: #fff;
    border-radius: 15px;
    letter-spacing: -0.02em;
    font-weight: 300;
    border: 1px solid #fff;
    isolation: isolate;
  }

  .herov2__cta--outline::before {
    content: "";
    position: absolute;
    top: 50%;
    left: -20px;
    width: 0;
    height: 0;
    background: var(--color-secondary);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: width 0.7s cubic-bezier(0.16, 1, 0.3, 1), height 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: -1;
  }

  .herov2__cta--outline:hover {
    color: #fff;
    border-color: #fff;
    transform: translateY(-2px);
  }

  .herov2__cta--outline:hover::before {
    width: 520px;
    height: 320px;
  }

  .herov2__cta--outline svg {
    transition: transform 0.4s ease;
  }

  .herov2__cta--outline:hover svg {
    transform: rotate(45deg);
  }

  .herov2__cta-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    transition: background 0.3s ease;
  }

  .herov2__cta--primary:hover .herov2__cta-arrow {
    background: rgba(255, 255, 255, 0.3);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .herov2__content {
      padding: 0 var(--space-2xl) var(--space-2xl);
    }
  }

  @media (max-width: 768px) {
    .herov2 {
      min-height: 100vh;
      height: 100svh;
    }

    .herov2__content {
      padding: 0 var(--space-md) var(--space-xl);
      padding-bottom: 40px;
    }

    .herov2__eyebrow {
      font-size: 10px;
      letter-spacing: 1.5px;
      gap: 8px;
      margin-bottom: var(--space-sm);
    }

    .herov2__title-block {
      gap: 6px;
      margin-bottom: var(--space-md);
      width: 100%;
    }

    .herov2__title-line {
      padding-left: var(--space-md);
      border-left-width: 2.5px;
    }

    .herov2__title,
    .herov2__title--sub {
      font-size: clamp(2rem, 8vw, 2.75rem);
      line-height: 0.95;
      letter-spacing: -1.5px;
    }

    .herov2__subtitle {
      font-size: 14px;
      line-height: 1.4;
      margin-bottom: var(--space-lg);
      max-width: 100%;
    }

    .herov2__buttons {
      width: 100%;
      flex-direction: column;
      gap: 12px;
    }

    .herov2__cta {
      width: 100%;
      justify-content: center;
      padding: 14px 24px;
    }
  }

  /* ── Animations ── */
  @keyframes v2FadeLeft {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes v2ImgReveal {
    from {
      opacity: 0;
      transform: scale(1.05);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .herov2__img {
    animation: v2ImgReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .herov2__eyebrow {
    animation: v2FadeLeft 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  .herov2__title-line--secondary {
    animation: v2FadeLeft 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.45s both;
  }

  .herov2__title-line--primary {
    animation: v2FadeLeft 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.6s both;
  }

  .herov2__subtitle {
    animation: v2FadeLeft 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.75s both;
  }

  .herov2__buttons {
    animation: v2FadeLeft 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.9s both;
  }
</style>
