---
import heroImg from "../../assets/background-planta.png";
import { Image } from "astro:assets";
import leaft from "../../assets/decoration/leaf.svg";
---

<section class="herov3" id="hero">
  <div class="herov3__bg">
    <Image
      src={heroImg}
      alt="Manos sembrando una planta en la tierra"
      class="herov3__img"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      quality={85}
    />
    <div class="herov3__overlay"></div>
    <div class="herov3__bottom-blur"></div>
  </div>

  <div class="herov3__content">
    <!-- Eyebrow -->
    <p class="herov3__eyebrow">
      <Image
        src={leaft}
        alt="Hoja"
        class="herov3__leaft"
        width={18}
        height={18}
        loading="eager"
      />
      Construimos un futuro mejor
    </p>

    <!-- Title -->
    <h1 class="herov3__title">
      Transformamos <span class="herov3__accent">vidas,</span><br />
      fortalecemos <span class="herov3__accent_2">comunidades,</span><br />
      construimos <span class="herov3__accent">país.</span>
    </h1>

    <!-- Subtitle -->
    <p class="herov3__subtitle">
      Impulsamos el desarrollo comunitario y la transformación social<br />
      desde la empatía y la acción.
    </p>

    <!-- Buttons -->
    <div class="herov3__buttons">
      <a
        href="/proyectos"
        class="herov3__cta herov3__cta--primary"
        id="hero-cta-v3"
      >
        Conoce nuestros proyectos
        <span class="herov3__cta-arrow">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
          >
        </span>
      </a>
      <a href="/vacantes" class="herov3__cta herov3__cta--outline">
        Trabaja con nosotros
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle
            cx="9"
            cy="7"
            r="4"></circle><line x1="19" x2="19" y1="8" y2="14"></line><line
            x1="22"
            x2="16"
            y1="11"
            y2="11"></line></svg
        >
      </a>
    </div>
  </div>
</section>

<style>
  .herov3 {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 700px;
    max-height: 1080px;
    overflow: hidden;
  }

  /* ── Background ── */
  .herov3__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .herov3__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .herov3__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.7) 0%,
      rgba(0, 0, 0, 0.4) 40%,
      rgba(0, 0, 0, 0.1) 65%,
      transparent 100%
    );
  }

  .herov3__bottom-blur {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 320px;
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
    background: linear-gradient(180deg, #fffefa00 0%, #fffefa08 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 100%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* ── Content ── */
  .herov3__content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    text-align: center;
    height: 100%;
    max-width: 1320px;
    margin-inline: auto;
    padding: 0 var(--space-3xl) var(--space-3xl);
  }

  /* ── Eyebrow ── */
  .herov3__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-sm);
  }

  .herov3__eyebrow::after {
    content: "";
    display: block;
    width: 40px;
    height: 1.5px;
    background: var(--color-secondary);
  }
  .herov3__eyebrow::before {
    content: "";
    display: block;
    width: 40px;
    height: 1.5px;
    background: var(--color-secondary);
  }

  /* ── Title ── */
  .herov3__title {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(2.25rem, 3.5vw + 0.5rem, 3.75rem);
    line-height: 0.9;
    letter-spacing: -3px;
    color: #fff;
    margin-bottom: 10px;
  }

  .herov3__accent {
    font-family: var(--font-title);
    font-style: italic;
    font-weight: 400;
    color: var(--color-secondary);
  }

  .herov3__accent_2 {
    font-family: var(--font-title);
    font-style: italic;
    font-weight: 400;
    color: #5cecd6;
  }

  /* ── Subtitle ── */
  .herov3__subtitle {
    font-family: var(--font-body);
    font-size: clamp(0.875rem, 1vw + 0.2rem, 1rem);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.5;
    margin-bottom: var(--space-lg);
    max-width: 520px;
  }

  /* ── Buttons ── */
  .herov3__buttons {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .herov3__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    padding: 12px 24px;
    border-radius: var(--radius-full);
    letter-spacing: 0.2px;
    transition: all 0.3s ease;
  }

  .herov3__cta--primary {
    color: #fff;
    border-radius: 15px;
    background: linear-gradient(1deg, #0b968a, #0a6967);
    letter-spacing: -0.025em;
    box-shadow:
      0px -1px #13ffeb,
      0px 1px #1ad3c3,
      0px 0px 0px 1px #0d968a;
    font-weight: 300;
    border: none;
  }

  .herov3__cta--primary:hover {
    transform: translateY(-2px);
    filter: brightness(1.1);
    box-shadow:
      0px -1px #13ffeb,
      0px 2px 8px rgba(26, 211, 195, 0.4),
      0px 0px 0px 1px #0d968a;
  }

  .herov3__cta--outline {
    position: relative;
    overflow: hidden;
    z-index: 1;
    color: var(--color-primary);
    background: #fff;
    border-radius: 15px;
    letter-spacing: -0.02em;
    font-weight: 300;
    border: 1px solid #fff;
    isolation: isolate;
  }

  .herov3__cta--outline::before {
    content: "";
    position: absolute;
    top: 50%;
    left: -20px;
    width: 0;
    height: 0;
    background: var(--color-secondary);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition:
      width 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      height 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: -1;
  }

  .herov3__cta--outline:hover {
    color: #fff;
    border-color: #fff;
    transform: translateY(-2px);
  }

  .herov3__cta--outline:hover::before {
    width: 520px;
    height: 320px;
  }

  .herov3__cta-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    transition: background 0.3s ease;
  }

  .herov3__cta--primary:hover .herov3__cta-arrow {
    background: rgba(255, 255, 255, 0.3);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .herov3__content {
      padding: 0 var(--space-2xl) var(--space-2xl);
    }
  }

  @media (max-width: 768px) {
    .herov3 {
      min-height: 100vh;
      height: 100svh;
    }

    .herov3__content {
      padding: 0 var(--space-md) var(--space-xl);
      justify-content: flex-end;
      padding-bottom: 40px;
    }

    .herov3__eyebrow {
      font-size: 10px;
      letter-spacing: 1.5px;
      gap: 8px;
      margin-bottom: var(--space-sm);
    }

    .herov3__eyebrow::before,
    .herov3__eyebrow::after {
      width: 20px;
    }

    .herov3__title {
      font-size: clamp(2rem, 8vw, 2.75rem);
      line-height: 0.95;
      letter-spacing: -1.5px;
      margin-bottom: var(--space-md);
    }

    .herov3__subtitle {
      font-size: 14px;
      line-height: 1.4;
      margin-bottom: var(--space-lg);
      padding: 0 var(--space-xs);
    }

    .herov3__buttons {
      width: 100%;
      flex-direction: column;
      gap: 12px;
      padding: 0 var(--space-sm);
    }

    .herov3__cta {
      width: 100%;
      justify-content: center;
      padding: 14px 24px;
    }
  }

  /* ── Animations ── */
  @keyframes v3FadeUp {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes v3ImgZoom {
    from {
      opacity: 0;
      transform: scale(1.2);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .herov3__img {
    animation: v3ImgZoom 1.2s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .herov3__eyebrow {
    animation: v3FadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.35s both;
  }

  .herov3__title {
    animation: v3FadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
  }

  .herov3__subtitle {
    animation: v3FadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.7s both;
  }

  .herov3__buttons {
    animation: v3FadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.85s both;
  }
</style>
