---
import mapaColombia from "../../assets/mapa-colombia.svg?raw";
---

<section class="sobre section" id="sobre">
  <div class="sobre-map" aria-hidden="true">
    <Fragment set:html={mapaColombia} />
  </div>
  <div class="wrap sobre-inner reveal">
    <span class="eyebrow center">Sobre Corppaz</span>
    <h2>
      Desarrollo social y fortalecimiento <span class="accent-italic"
        >comunitario</span
      > para el campo colombiano.
    </h2>
    <p>
      Trabajamos con profesionalismo, esperanza y comunidad: experiencia,
      transformación social con proyección al futuro, y calidad humana con cada
      territorio que acompañamos desde 2016.
    </p>
    <a href="#contacto" class="btn btn-solid">Contáctanos</a>
  </div>
  <div class="wrap sobre-stats reveal">
    <div class="stat">
      <div class="num" data-target="35771" data-suffix="+">0+</div>
      <div class="lbl">Kits de alimentos entregados</div>
    </div>
    <div class="stat">
      <div class="num" data-target="120" data-suffix="+">0+</div>
      <div class="lbl">Proyectos ejecutados</div>
    </div>
    <div class="stat">
      <div class="num" data-target="10" data-suffix="+">0+</div>
      <div class="lbl">Años transformando comunidades</div>
    </div>
    <div class="stat">
      <div class="num" data-target="23" data-suffix="">0</div>
      <div class="lbl">Alcaldías aliadas en el país</div>
    </div>
  </div>
</section>

<style>
  /* Variables locales de compatibilidad */
  .sobre {
    --primary: var(--color-primary, #043a39);
    --secondary: var(--color-secondary, #f8aea1);
    --secondary-deep: #ef8f7d;
    --bg: var(--color-bg, #faf8f5);
    --surface: var(--color-surface, #ffffff);
    --text-soft: #5b6360;
    --divider: var(--color-divider, #e8e8e8);
    --font-display: var(--font-title, "DM Serif Display", serif);
    --font-accent: var(--font-serif, "Instrument Serif", serif);
  }

  /* ===== ESTILOS LOCALES / UTILIDADES ===== */
  .wrap {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 clamp(24px, 6vw, 96px);
  }

  .eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--secondary-deep);
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
  }

  .eyebrow::before {
    content: "";
    width: 22px;
    height: 1px;
    background: var(--secondary-deep);
    display: inline-block;
  }

  .eyebrow.center {
    justify-content: center;
  }

  .accent-italic {
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 500;
    color: var(--secondary-deep);
    letter-spacing: 0.04rem;
  }

  .section {
    padding: min(14vw, 120px) 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 15px 30px;
    border-radius: 100px;
    font-weight: 600;
    font-size: 0.92rem;
    transition:
      transform 0.25s ease,
      background 0.25s ease,
      color 0.25s ease;
  }

  .btn-solid {
    background: var(--secondary);
    color: var(--primary);
  }

  .btn-solid:hover {
    background: var(--secondary-deep);
    transform: translateY(-2px);
  }

  .stat {
    text-align: center;
    position: relative;
    padding: 0 20px;
  }

  .stat:not(:last-child)::after {
    content: "";
    position: absolute;
    right: 0;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: var(--divider);
  }

  .stat .num {
    font-family: var(--font-body);
    font-size: clamp(2.2rem, 4.4vw, 3.4rem);
    color: var(--primary);
    font-weight: 600;
    letter-spacing: -0.04rem;
  }

  .stat .lbl {
    color: var(--text-soft);
    font-size: 0.9rem;
    margin-top: 6px;
  }

  /* ===== SOBRE CORPPAZ (mapa de fondo) ===== */
  .sobre {
    position: relative;
    background: var(--bg);
    overflow: hidden;
  }

  .sobre-map {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 0;
    padding: min(8vw, 64px);
    box-sizing: border-box;
  }

  /* Usamos :global para estilos aplicados al SVG inyectado en runtime */
  .sobre-map :global(svg) {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    display: block;
  }

  .sobre-map :global(.dept) {
    fill: rgba(4, 58, 57, 0.05);
    stroke: rgba(4, 58, 57, 0.09);
    stroke-width: 1;
    transition: fill 0.3s;
  }

  .sobre-map :global(.dept-active) {
    fill: rgba(4, 58, 57, 0.1);
    stroke: rgba(4, 58, 57, 0.18);
    stroke-width: 1;
  }

  .sobre-inner {
    position: relative;
    z-index: 1;
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 26px;
  }

  .sobre-inner h2 {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: clamp(2rem, 4.4vw, 3.3rem);
    line-height: 1.08;
    color: var(--primary);
    letter-spacing: -0.02em;
  }

  .sobre-inner p {
    color: var(--text-soft);
    font-size: 1.05rem;
    max-width: 62ch;
    letter-spacing: -0.02em;
  }

  .sobre-stats {
    position: relative;
    z-index: 1;
    margin-top: 74px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--divider);
    padding-top: 54px;
  }

  /* ===== ANIMACIONES REVEAL LOCALES ===== */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.8s ease,
      transform 0.8s ease;
  }

  .reveal.in {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 860px) {
    .sobre-stats {
      grid-template-columns: repeat(2, 1fr);
      row-gap: 38px;
    }

    .sobre-map {
      width: 220vw;
    }
  }

  @media (max-width: 700px) {
    .stat:not(:last-child)::after {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .sobre-stats {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  const setupRevealAndStats = () => {
    const section = document.getElementById("sobre");
    if (!section) return;

    // 1. Animaciones de Reveal
    const els = section.querySelectorAll(".reveal");
    const ioReveal = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("in");
            ioReveal.unobserve(e.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    els.forEach((el) => ioReveal.observe(el));

    // 2. Animación Incremental de Estadísticas (Contadores)
    const statsContainer = section.querySelector(".sobre-stats");
    const statNums = section.querySelectorAll(".stat .num");

    if (statsContainer && statNums.length > 0) {
      const ioStats = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              statNums.forEach((numEl) => {
                const targetVal = parseFloat(numEl.getAttribute("data-target") || "0");
                const suffix = numEl.getAttribute("data-suffix") || "";
                const obj = { val: 0 };

                gsap.to(obj, {
                  val: targetVal,
                  duration: 2.2,
                  ease: "power2.out",
                  onUpdate: () => {
                    // Formateador regional para añadir los puntos de los miles en español
                    const formatted = Math.floor(obj.val).toLocaleString("es-CO");
                    numEl.textContent = formatted + suffix;
                  }
                });
              });
              ioStats.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      ioStats.observe(statsContainer);
    }
  };

  // Se ejecuta al cargar la página
  setupRevealAndStats();
  // Compatible con transiciones de página de Astro
  document.addEventListener("astro:after-swap", setupRevealAndStats);
</script>
