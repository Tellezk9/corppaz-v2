---
import imagotipo from "../assets/imagotipo.png";
import { Image } from "astro:assets";
---

<nav class="navbar" id="navbar">
  <div class="navbar__inner">
    <!-- Logo -->
    <a href="/" class="navbar__logo" aria-label="CORPPAZ - Inicio">
      <Image
        src={imagotipo}
        alt="CORPPAZ"
        height={36}
        class="navbar__logo-img"
      />
    </a>

    <!-- Hamburger Toggle -->
    <button
      class="navbar__toggle"
      id="navbar-toggle"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <span class="navbar__toggle-line"></span>
      <span class="navbar__toggle-line"></span>
      <span class="navbar__toggle-line"></span>
    </button>

    <!-- Menu Wrapper -->
    <div class="navbar__menu" id="navbar-menu">
      <!-- Navigation Links -->
      <ul class="navbar__links">
        <li>
          <a
            href="/"
            class="navbar__link navbar__link--active"
            aria-current="page"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"></path><path
                d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
              ></path></svg
            >
            Inicio
          </a>
        </li>
        <li>
          <a href="/servicios" class="navbar__link">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
              ></path></svg
            >
            Servicios
          </a>
        </li>
        <li>
          <a href="/nosotros" class="navbar__link">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"
              ></path><circle cx="9" cy="7" r="4"></circle><path
                d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path
                d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg
            >
            Nosotros
          </a>
        </li>
        <li class="navbar__dropdown">
          <button class="navbar__link navbar__link--dropdown" type="button">
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2Z"
              ></path></svg
            >
            Proyectos
            <svg
              class="navbar__chevron"
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg
            >
          </button>
          <div class="navbar__dropdown-panel">
            <a href="/hero/v1" class="navbar__dropdown-item">Hero v1</a>
            <a href="/hero/v2" class="navbar__dropdown-item">Hero v2</a>
            <a href="/hero/v3" class="navbar__dropdown-item">Hero v3</a>
          </div>
        </li>
      </ul>

      <!-- Action Buttons -->
      <div class="navbar__actions">
        <a href="/contacto" class="navbar__btn navbar__btn--solid">
          Contáctanos
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
          >
        </a>
      </div>
    </div>
  </div>
</nav>

<style>
  @keyframes navSlideDown {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
  }

  .navbar {
    position: absolute;
    top: var(--space-lg);
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - var(--space-3xl));
    max-width: 1320px;
    z-index: 100;
    width: 60%;
    animation: navSlideDown 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: var(--radius-full);
    padding: var(--space-sm) var(--space-sm) var(--space-sm) var(--space-md);
    border: 1px solid rgba(232, 232, 232, 0.6);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }

  /* ── Logo ── */
  .navbar__logo-img {
    height: 36px;
    width: auto;
    display: block;
  }

  /* ── Links ── */
  .navbar__links {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin: 0 auto;
  }

  .navbar__link {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-dark);
    padding: 8px 16px;
    border-radius: var(--radius-full);
    transition:
      background 0.2s ease,
      color 0.2s ease;
    white-space: nowrap;
  }

  .navbar__link:hover {
    background: rgba(107, 143, 60, 0.06);
    color: var(--color-primary);
  }

  .navbar__link--active {
    color: var(--color-secondary);
  }

  .navbar__link--active:hover {
    color: var(--color-secondary-dark);
    background: rgba(200, 132, 42, 0.06);
  }

  .navbar__link--dropdown {
    cursor: pointer;
    border: none;
    background: transparent;
    width: 100%;
    text-align: left;
  }

  .navbar__chevron {
    transition: transform 0.2s ease;
  }

  .navbar__link--dropdown:hover .navbar__chevron {
    transform: translateY(1px);
  }

  /* ── Dropdown ── */
  .navbar__dropdown {
    position: relative;
  }

  .navbar__dropdown-panel {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 200px;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: var(--radius-md);
    border: 1px solid rgba(232, 232, 232, 0.6);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    padding: var(--space-xs);
    opacity: 0;
    visibility: hidden;
    transform: translateX(-50%) translateY(-4px);
    transition: all 0.2s ease;
    z-index: 100;
  }

  .navbar__dropdown:hover .navbar__dropdown-panel {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .navbar__dropdown:hover .navbar__chevron {
    transform: rotate(180deg);
  }

  .navbar__dropdown-item {
    display: block;
    padding: 10px 16px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-dark);
    border-radius: var(--radius-sm);
    transition:
      background 0.15s ease,
      color 0.15s ease;
    white-space: nowrap;
  }

  .navbar__dropdown-item:hover {
    background: rgba(4, 58, 57, 0.06);
    color: var(--color-primary);
  }

  /* ── Menu Wrapper ── */
  .navbar__menu {
    display: flex;
    align-items: center;
    flex-grow: 1;
    margin-left: var(--space-lg);
  }

  /* ── Hamburger Toggle ── */
  .navbar__toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 16px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 110;
  }

  .navbar__toggle-line {
    width: 100%;
    height: 2px;
    background-color: var(--color-dark);
    border-radius: 2px;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ── Action Buttons ── */
  .navbar__actions {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-shrink: 0;
  }

  .navbar__btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 600;
    padding: 10px 20px;
    border-radius: var(--radius-full);
    transition: all 0.25s ease;
    white-space: nowrap;
    letter-spacing: 0.2px;
  }

  .navbar__btn--outline {
    border: 1.5px solid var(--color-divider);
    color: var(--color-dark);
    background: transparent;
  }

  .navbar__btn--outline:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: rgba(107, 143, 60, 0.04);
  }

  .navbar__btn--solid {
    background-image: linear-gradient(135deg, var(--color-secondary) 0%, #e07f6e 100%);
    box-shadow: 0 5px 5px -1px rgba(224, 127, 110, 0.5);
    color: #fff;
    border: none;
    transition: all 0.3s ease-in-out;
  }

  .navbar__btn--solid:hover {
    transform: translateY(3px);
    box-shadow: none;
  }

  .navbar__btn--solid:active {
    opacity: 0.5;
  }

  /* ── Mobile Responsive Navbar ── */
  @media (max-width: 992px) {
    .navbar {
      width: 90%;
    }
  }

  @media (max-width: 768px) {
    .navbar {
      width: 92%;
    }

    .navbar__inner {
      padding: var(--space-sm) var(--space-md);
      position: relative;
    }

    .navbar__toggle {
      display: flex;
    }

    /* Menu drawer layout */
    .navbar__menu {
      position: absolute;
      top: calc(100% + 10px);
      left: 0;
      right: 0;
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-radius: var(--radius-lg);
      border: 1px solid rgba(232, 232, 232, 0.8);
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
      padding: var(--space-lg);
      flex-direction: column;
      align-items: stretch;
      gap: var(--space-md);
      margin-left: 0;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-8px);
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* Open Menu State */
    .navbar--open .navbar__menu {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    /* Hamburger transformation to 'X' */
    .navbar--open .navbar__toggle-line:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .navbar--open .navbar__toggle-line:nth-child(2) {
      opacity: 0;
      transform: scale(0);
    }

    .navbar--open .navbar__toggle-line:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    .navbar__links {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
      gap: var(--space-xs);
      margin: 0;
    }

    .navbar__link {
      width: 100%;
      padding: 12px 16px;
      border-radius: var(--radius-md);
    }

    /* Dropdown inside mobile drawer */
    .navbar__dropdown-panel {
      position: static;
      transform: none !important;
      opacity: 1;
      visibility: visible;
      box-shadow: none;
      border: none;
      background: rgba(4, 58, 57, 0.03);
      padding: var(--space-xs) 0 var(--space-xs) var(--space-md);
      display: none;
      width: 100%;
      border-radius: var(--radius-sm);
      margin-top: var(--space-xs);
    }

    .navbar__dropdown--active .navbar__dropdown-panel {
      display: block;
    }

    .navbar__dropdown--active .navbar__chevron {
      transform: rotate(180deg);
    }

    .navbar__actions {
      width: 100%;
      margin-top: var(--space-xs);
    }

    .navbar__btn {
      width: 100%;
      justify-content: center;
      padding: 12px 20px;
    }
  }
</style>

<script>
  const toggleBtn = document.getElementById("navbar-toggle");
  const navbar = document.getElementById("navbar");
  const dropdownBtn = document.querySelector(".navbar__link--dropdown");
  const dropdownLi = document.querySelector(".navbar__dropdown");

  if (toggleBtn && navbar) {
    toggleBtn.addEventListener("click", () => {
      const isOpen = navbar.classList.toggle("navbar--open");
      toggleBtn.setAttribute("aria-expanded", String(isOpen));
    });
  }

  if (dropdownBtn && dropdownLi) {
    dropdownBtn.addEventListener("click", (e) => {
      if (window.innerWidth <= 768) {
        e.preventDefault();
        dropdownLi.classList.toggle("navbar__dropdown--active");
      }
    });
  }
</script>
